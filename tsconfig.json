{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "types": ["vite/client", "node"],   // added "node" for vite.config
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,                    // Vite handles output
    "moduleDetection": "force",
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "$lib/*": ["./src/lib/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte",
    "vite.config.ts"                  // include the config file
  ]
}